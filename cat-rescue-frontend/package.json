{
  "name": "cat-rescue-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:user": "cross-env VITE_APP_TYPE=user vite --port 3000",
    "dev:rescuer": "cross-env VITE_APP_TYPE=rescuer vite --port 3001",
    "dev:admin": "cross-env VITE_APP_TYPE=admin vite --port 3002",
    "dev:all": "concurrently \"npm run dev:user\" \"npm run dev:rescuer\" \"npm run dev:admin\"",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.1.0",
    "@stomp/stompjs": "^7.3.0",
    "@tensorflow/tfjs": "^4.22.0",
    "axios": "^1.4.0",
    "echarts": "^6.0.0",
    "element-plus": "^2.3.8",
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
    "pinia": "^2.1.6",
    "vue": "^3.3.4",
    "vue-router": "^4.2.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^18.16.17",
    "@vitejs/plugin-vue": "^4.2.3",
    "@vue/eslint-config-prettier": "^8.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.45.0",
    "eslint-plugin-vue": "^9.15.1",
    "prettier": "^3.0.0",
    "vite": "^4.4.5"
  }
}
